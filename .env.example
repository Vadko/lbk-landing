# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Images URL
NEXT_PUBLIC_STORAGE_IMAGES_URL=https://..

# GitHub Token (for releases)
GITHUB_TOKEN=github_pat_xxx

# Redis URL
REDIS_URL=....

# Revalidation Secret (must match LBK_LANDING_REVALIDATE_SECRET in lbk-translations)
REVALIDATE_SECRET=your-secret-here

# Sentry / GlitchTip
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-glitchtip-instance.com/1
SENTRY_AUTH_TOKEN=your-auth-token
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_URL=https://your-glitchtip-instance.com